# ============================================================
# Application
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guildpass"

# ============================================================
# Cache (optional — reserved for future use)
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# Observability — Logging
# ============================================================

# Minimum log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ============================================================
# Observability — Metrics
# ============================================================

# If set, the /metrics endpoint requires:  Authorization: Bearer <token>
# Leave empty to disable auth on the metrics endpoint (dev only).
METRICS_TOKEN=

# ============================================================
# Contracts (fill after deployment)
# ============================================================
MEMBERSHIP_NFT_ADDRESS=""
CHAIN_ID=31337
